# Скопируйте этот файл в .env и заполните реальными значениями.
# Файл .env НЕ должен попадать в git (см. .gitignore).
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_IDS=your_telegram_user_id
# PostgreSQL connection string. На Railway используйте Variable Reference на
# сервис PostgreSQL: DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/carcollection
